generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  contracts Contract[]

  createdAt DateTime @default(now())
}

model Contract {
  id String @id @default(cuid())

  contractId String @unique

  freelancerType String

  clientName String

  projectValue Float

  deposit Int

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
